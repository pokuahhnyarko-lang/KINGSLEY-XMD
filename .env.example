# ==============================
# KINGSLEY-XMD Bot Configuration
# ==============================

# Session ID from pair site (required)
SESSION_ID=

# Bot owner WhatsApp number (with country code, no +)
OWNER_NUMBER=2348012345678

# Command prefix
PREFIX=.

# Bot name
BOT_NAME=KINGSLEY-XMD

# Bot mode: public or private
BOT_MODE=public

# Auto-read messages (true/false)
AUTO_READ=true

# Auto-typing indicator (true/false)
AUTO_TYPING=true

# Auto-recording indicator (true/false)
AUTO_RECORDING=false

# Log level (info, debug, error)
LOG_LEVEL=info

# Pair server port
PAIR_PORT=5000

# Anti-spam (messages per minute)
ANTI_SPAM=10

# Timezone
TIMEZONE=Africa/Lagos

# Database (optional - for advanced features)
# DATABASE_URL=

# APIs (optional)
GEMINI_API_KEY=
OPENAI_API_KEY=
