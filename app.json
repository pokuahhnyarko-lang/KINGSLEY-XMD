{
  "name": "KINGSLEY-XMD",
  "description": "Advanced WhatsApp Bot powered by Baileys",
  "repository": "https://github.com/KINGSLEY-XMD/KINGSLEY-XMD",
  "logo": "https://raw.githubusercontent.com/KINGSLEY-XMD/KINGSLEY-XMD/main/assets/logo.png",
  "keywords": ["whatsapp", "bot", "baileys"],
  "env": {
    "SESSION_ID": {
      "description": "WhatsApp session ID from pair site",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number without + (e.g. 2348012345678)",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": false
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "value": "KINGSLEY-XMD",
      "required": false
    },
    "BOT_MODE": {
      "description": "public or private",
      "value": "public",
      "required": false
    },
    "TIMEZONE": {
      "description": "Your timezone",
      "value": "Africa/Lagos",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "free"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
